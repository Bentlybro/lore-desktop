{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lore-desktop",
  "version": "0.1.0",
  "identifier": "com.bentlybro.loredesktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lore Desktop",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
